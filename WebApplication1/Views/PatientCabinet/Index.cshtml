@model IEnumerable<WebApplication1.Models.RecordingSlot>
@{
    ViewData["Title"] = "Личный кабинет пациента";
    var patient = ViewBag.Patient as WebApplication1.Models.Patient;
}

<div class="container mt-4">
    <h2>👤 Личный кабинет пациента</h2>
    
    @if (patient != null)
    {
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Информация о пациенте</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>ФИО:</strong> @patient.FullName</p>
                        <p><strong>Email:</strong> @patient.Email</p>
                        <p><strong>Телефон:</strong> @patient.Phone</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Дата рождения:</strong> @patient.BirthDate.ToString("dd.MM.yyyy")</p>
                        <p><strong>Номер полиса:</strong> @patient.InsuranceNumber</p>
                        <p><strong>Пол:</strong> @patient.Gender</p>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">📋 История записей</h4>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Дата</th>
                            <th>Время</th>
                            <th>Врач</th>
                            <th>Специализация</th>
                            <th>Услуга</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in Model)
                        {
                            var isPast = slot.Date < DateOnly.FromDateTime(DateTime.Now) || 
                                        (slot.Date == DateOnly.FromDateTime(DateTime.Now) && slot.StartTime < TimeOnly.FromDateTime(DateTime.Now));
                            var statusClass = isPast ? "text-muted" : "text-success fw-bold";
                            var statusText = isPast ? "Завершен" : "Запланирован";

                            <tr>
                                <td>@slot.Date.ToString("dd.MM.yyyy")</td>
                                <td>@slot.StartTime.ToString("HH:mm")</td>
                                <td>@slot.Doctor?.FullName</td>
                                <td>@slot.Doctor?.Specialization?.Name</td>
                                <td>@slot.Service?.Name</td>
                                <td class="@statusClass">@statusText</td>
                                <td>
                                    @if (!isPast)
                                    {
                                        <form asp-action="Cancel" method="post" style="display:inline;" 
                                              onsubmit="return confirm('Вы уверены, что хотите отменить запись?');">
                                            <input type="hidden" name="id" value="@slot.SlotId" />
                                            <button type="submit" class="btn btn-sm btn-danger">Отменить</button>
                                        </form>
                                        
                                        <a asp-action="Reschedule" asp-route-id="@slot.SlotId" 
                                           class="btn btn-sm btn-warning">Перенести</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ccc;"></i>
                    <h5 class="mt-3 text-muted">У вас пока нет записей</h5>
                    <p class="text-muted">Запишитесь на прием к врачу через каталог специалистов</p>
                    <a asp-controller="Doctors" asp-action="Index" class="btn btn-primary mt-2">
                        📋 Перейти к каталогу врачей
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-primary">
            🔍 Найти врача
        </a>
        <a asp-controller="Appointments" asp-action="Create" class="btn btn-success ms-2">
            ✏️ Записаться на прием
        </a>
    </div>
</div>

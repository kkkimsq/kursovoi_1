@model WebApplication1.Models.Appointment

@{
    ViewData["Title"] = "Изменить";
}

<h1>Изменить</h1>

<h4>Прием</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AppointmentId" />
            <div class="form-group">
                <label class="control-label">Диагноз</label>
                <input asp-for="Diagnosis" class="form-control" />
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Рекомендации</label>
                <input asp-for="Recommendations" class="form-control" />
                <span asp-validation-for="Recommendations" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FinalCost" class="control-label">Итоговая сумма</label>
                <input asp-for="FinalCost"
                       class="form-control"
                       type="number"
                       step="0.01"
                       min="0.01"
                       placeholder="0.00" />
                <span asp-validation-for="FinalCost" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Дата создания</label>
                <input asp-for="CreationDate" class="form-control" />
                <span asp-validation-for="CreationDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Вернуться</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
